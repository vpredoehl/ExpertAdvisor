          RowBox[{"x", ",", 
           RowBox[{"{", 
            RowBox[{"inputs", "[", 
             RowBox[{"[", "t", "]"}], "]"}], "}"}]}], "}"}]}], "]"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
