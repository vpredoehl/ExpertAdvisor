          RowBox[{
          "activations", " ", "by", " ", "contiguous", " ", "blocks"}]}], 
         "*)"}], 
        RowBox[{"iPre", "=", 
         RowBox[{"y", "[", 
          RowBox[{"[", 
           RowBox[{"1", ";;", "nOut"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"fPre", "=", 
         RowBox[{"y", "[", 
          RowBox[{"[", 
           RowBox[{
