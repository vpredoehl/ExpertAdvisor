            RowBox[{"t", "-", "1"}], "}"}]}]}], "]"}], "*)"}], 
       RowBox[{
        RowBox[{"xh", "=", 
         RowBox[{"Join", "[", 
          RowBox[{"x", ",", "hPrev"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
