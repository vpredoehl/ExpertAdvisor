            RowBox[{"2", " ", "nOut"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"gPre", "=", 
         RowBox[{"y", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{"2", " ", "nOut"}], "+", "1"}], ";;", 
            RowBox[{"3", " ", "nOut"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"oPre", "=", 
         RowBox[{"y", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{"3", " ", "nOut"}], "+", "1"}], ";;", 
            RowBox[{"4", " ", "nOut"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"Gate", " ", "activations"}], "*)"}], 
        RowBox[{"i", "=", 
         RowBox[{"sigmoid", "[", "iPre", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"f", "=", 
         RowBox[{"sigmoid", "[", "fPre", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"g", "=", 
         RowBox[{"Tanh", "[", "gPre", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"o", "=", 
         RowBox[{"sigmoid", "[", "oPre", "]"}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"(*", 
         RowBox[{"LSTM", " ", "updates"}], "*)"}], 
        RowBox[{"cT", "=", 
         RowBox[{
          RowBox[{"f", "*", "cPrev"}], "+", 
          RowBox[{"i", "*", "g"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"hT", "=", 
         RowBox[{"o", "*", 
          RowBox[{"Tanh", "[", "cT", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<xh\>\"", "->", "xh"}], ",", 
          RowBox[{"\"\<y\>\"", "->", "y"}], ",", 
          RowBox[{"\"\<i\>\"", "->", "i"}], ",", 
          RowBox[{"\"\<f\>\"", "->", "f"}], ",", 
          RowBox[{"\"\<g\>\"", "->", "g"}], ",", 
          RowBox[{"\"\<o\>\"", "->", "o"}], ",", 
          RowBox[{"\"\<c\>\"", "->", "cT"}], ",", 
          RowBox[{"\"\<h\>\"", "->", "hT"}]}], "|>"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Run", " ", "over", " ", "the", " ", "5"}], "-", 
      RowBox[{"step", " ", "window"}]}], ",", 
     RowBox[{"updating", " ", 
      RowBox[{"cPrev", "/", "hPrev"}], " ", "after", " ", "each", " ", 
      "step"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"steps", "=", 
     RowBox[{
      RowBox[{"Reap", "[", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"step", "=", 
           RowBox[{"LSTMStep", "[", 
            RowBox[{"x", ",", "cPrev", ",", "hPrev"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"cPrev", "=", 
           RowBox[{"step", "[", "\"\<c\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"hPrev", "=", 
           RowBox[{"step", "[", "\"\<h\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Sow", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<t\>\"", "->", "t"}], ",", 
             RowBox[{"\"\<x\>\"", "->", "x"}], ",", 
             RowBox[{"\"\<xh\>\"", "->", 
              RowBox[{"step", "[", "\"\<xh\>\"", "]"}]}], ",", 
             RowBox[{"\"\<y\>\"", "->", 
              RowBox[{"step", "[", "\"\<y\>\"", "]"}]}], ",", 
             RowBox[{"\"\<yReshaped\>\"", "->", 
              RowBox[{"ArrayReshape", "[", 
               RowBox[{
                RowBox[{"step", "[", "\"\<y\>\"", "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"4", ",", "nOut"}], "}"}]}], "]"}]}], ",", 
             RowBox[{"(*", 
              RowBox[{"matches", " ", "gates2D", " ", "in", " ", 
               RowBox[{"C", "++"}]}], "*)"}], 
             RowBox[{"\"\<i\>\"", "->", 
              RowBox[{"step", "[", "\"\<i\>\"", "]"}]}], ",", 
             RowBox[{"\"\<f\>\"", "->", 
              RowBox[{"step", "[", "\"\<f\>\"", "]"}]}], ",", 
             RowBox[{"\"\<g\>\"", "->", 
              RowBox[{"step", "[", "\"\<g\>\"", "]"}]}], ",", 
             RowBox[{"\"\<o\>\"", "->", 
              RowBox[{"step", "[", "\"\<o\>\"", "]"}]}], ",", 
             RowBox[{"\"\<c\>\"", "->", 
              RowBox[{"step", "[", "\"\<c\>\"", "]"}]}], ",", 
             RowBox[{"\"\<h\>\"", "->", 
              RowBox[{"step", "[", "\"\<h\>\"", "]"}]}]}], "|>"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "1", ",", 
