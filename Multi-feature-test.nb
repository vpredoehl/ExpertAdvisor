     RowBox[{"ConstantArray", "[", 
      RowBox[{"0.0", ",", "nOut"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", "Activations", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"sigmoid", "[", "v_", "]"}], ":=", 
     RowBox[{"1.0", "/", 
      RowBox[{"(", 
       RowBox[{"1.0", "+", 
        RowBox[{"Exp", "[", 
         RowBox[{"-", "v"}], "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{"One", " ", "LSTM", " ", "step", " ", "that", " ", "mirrors", " ", 
