Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Parameters", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"featureSize", "=", "4"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hiddenSize", "=", "8"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nIn", "=", 
     RowBox[{"featureSize", "+", "hiddenSize"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nOut", "=", "hiddenSize"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"weightInit", "=", "0.1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"biasInit", "=", "0.0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Test", " ", "input", " ", "x_t", " ", 
     RowBox[{"(", 
      RowBox[{"row", " ", "vector", " ", "length", " ", "featureSize"}], 
      ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"{", 
      RowBox[{
      "1.00879", ",", " ", "1.00869", ",", " ", "1.00898", ",", " ", 
       "1.00848"}], "}"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "replace", " ", "with", " ", "numeric", " ", "values", " ", "for", " ", 
     "a", " ", "concrete", " ", "test"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Previous", " ", "states"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"hPrev", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0.0", ",", "nOut"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cPrev", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0.0", ",", "nOut"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Build", " ", "xh"}], "=", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{"x_t", ",", "h_prev"}], "]"}], " ", "length", " ", "nIn"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"xh", "=", 
     RowBox[{"Join", "[", 
      RowBox[{"x", ",", "hPrev"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Build", " ", 
     RowBox[{"W", ":", 
      RowBox[{"nIn", " ", "x", " ", 
       RowBox[{"(", 
        RowBox[{"4", "*", "nOut"}], ")"}], " ", "all", " ", "0.1"}]}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"W", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"weightInit", ",", 
       RowBox[{"{", 
        RowBox[{"nIn", ",", 
         RowBox[{"4", " ", "nOut"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Bias", " ", 
     RowBox[{"b", ":", 
      RowBox[{"length", " ", "4", "*", "nOut", " ", "all", " ", "0.0"}]}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"b", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"biasInit", ",", 
       RowBox[{"4", " ", "nOut"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Linear", " ", "output", " ", 
     RowBox[{"y", ":", 
      RowBox[{"shape", " ", 
       RowBox[{"(", 
        RowBox[{"4", "*", "nOut"}], ")"}], " ", "since", " ", "xh", " ", "is",
        " ", "1", " ", "x", " ", "nIn"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"y", "=", 
     RowBox[{
      RowBox[{"xh", ".", "W"}], "+", "b"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Split", " ", "into", " ", "gates", " ", "by", " ", "contiguous", " ", 
     "blocks", " ", "of", " ", "length", " ", "nOut"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"iPre", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"y", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "nOut"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"fPre", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"y", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"nOut", "+", "1"}], ",", 
         RowBox[{"2", " ", "nOut"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gPre", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"y", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"2", " ", "nOut"}], "+", "1"}], ",", 
         RowBox[{"3", " ", "nOut"}]}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"oPre", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"y", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"3", " ", "nOut"}], "+", "1"}], ",", 
         RowBox[{"4", " ", "nOut"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Activations", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"sigmoid", "[", "v_", "]"}], ":=", 
     RowBox[{"1.0", "/", 
      RowBox[{"(", 
       RowBox[{"1.0", "+", 
        RowBox[{"Exp", "[", 
         RowBox[{"-", "v"}], "]"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"i", "=", 
     RowBox[{"sigmoid", "[", "iPre", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"f", "=", 
     RowBox[{"sigmoid", "[", "fPre", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"g", "=", 
     RowBox[{"Tanh", "[", "gPre", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"o", "=", 
     RowBox[{"sigmoid", "[", "oPre", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "Updates", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cT", "=", 
     RowBox[{
      RowBox[{"f", "*", "cPrev"}], "+", 
      RowBox[{"i", "*", "g"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"hT", "=", 
     RowBox[{"o", "*", 
      RowBox[{"Tanh", "[", "cT", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"Output", " ", "results"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"{", 
